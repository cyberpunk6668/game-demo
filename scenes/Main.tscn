script = ExtResource("3_temporalprop")
PropName = "Diary"
DisplayName = "书桌日记"
TextDayMinus3 = "纸张几乎空白。旁边压着两张未拆封电影票：后天是手儿奈的生日。"
TextDayZero = "一封写了一半的道别信。字迹越到后面越凌乱，像被雨水和手指一起擦散。"
TextDayPlus7 = "纸页上密密麻麻画满了时空推导式。每一行都在试图证明无法证明的事。"

