position = Vector2(790, 385)
script = ExtResource("3_temporalprop")
PropName = "Recorder"
DisplayName = "桌面录音机"
TextDayMinus3 = "磁带里传来她轻快的声音：‘小竹田，记得今晚的电影哦！’"
TextDayZero = "磁带卡死在沙沙盲音里。电话线被拔掉，像一条死去的黑蛇。"
TextDayPlus7 = "警方留言断断续续：‘请问是小竹田先生吗？关于手儿奈小姐的坠轨事故……’"
ColorDayMinus3 = Color(0.95, 0.75, 0.35, 1)
